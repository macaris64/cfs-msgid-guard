{
  "name": "cfs-msgid-guard",
  "version": "1.0.0",
  "description": "GitHub Action and CLI to detect Message ID collisions in NASA cFS missions",
  "author": "macaris64",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/macaris64/cfs-msgid-guard.git"
  },
  "homepage": "https://github.com/macaris64/cfs-msgid-guard#readme",
  "bugs": {
    "url": "https://github.com/macaris64/cfs-msgid-guard/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "cfs-msgid-guard": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/index.js",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:action && npm run build:cli",
    "build:action": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "build:cli": "ncc build src/cli.ts -o dist/cli-tmp && printf '#!/usr/bin/env node\\n' | cat - dist/cli-tmp/index.js > dist/cli.js && rm -rf dist/cli-tmp",
    "test": "jest --verbose",
    "test:coverage": "jest --verbose --coverage",
    "test:manual": "node dist/cli.js --scan-path __tests__/fixtures --topicid-pattern '**/real/*_topicids.h'",
    "lint": "eslint src/ __tests__/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cfs",
    "nasa",
    "flight-software",
    "github-action",
    "message-id",
    "collision-detection",
    "cli"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@actions/core": "^1.11.0",
    "@actions/glob": "^0.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
